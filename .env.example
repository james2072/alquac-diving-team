# =============================================================================
# To switch LLM source, change only these 3 lines:
#   LLM_API_KEY   – your personal API key
#   LLM_BASE_URL  – the API endpoint
#   LLM_MODEL     – the model name recognised by that endpoint
# =============================================================================

# ── Option A: Google AI Studio (Gemini / Gemma) ───────────────────────────────
# Google exposes an OpenAI-compatible endpoint — no extra library needed.
# Get your key at: https://aistudio.google.com/app/apikey
# Available models: gemini-2.0-flash, gemini-1.5-pro, gemma-3-27b-it, …
LLM_API_KEY=AIza-your-google-ai-studio-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash-lite

# ── Option B: OpenAI cloud ────────────────────────────────────────────────────
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── Option C: Ollama (local, no key needed) ───────────────────────────────────
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# ── Embedding Model ───────────────────────────────────────────────────────────
# Runs locally via sentence-transformers — no API key needed.
# Note: Hardware device (cuda vs cpu) is now automatically detected in realtime.
EMBEDDING_MODEL=BAAI/bge-m3         # Multilingual/Vietnamese optimized model

# ── RAG settings ──────────────────────────────────────────────────────────────
CHUNK_MIN_TOKENS=30     # drop chunks shorter than this many tokens
NUM_RESULTS=5           # top-k articles retrieved per query

# ── alquc competition token ──────────────────────────────────────────────────────────────
ALQAC_TOKEN=alqac_a31c9PwVSEOBYeyQEImtS6QyPy8YR9gw