# =============================================================================
# To switch LLM source, change only these 3 lines:
#   LLM_API_KEY   – your personal API key
#   LLM_BASE_URL  – the API endpoint
#   LLM_MODEL     – the model name recognised by that endpoint
# =============================================================================
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=your-llm-api-provider-url
LLM_MODEL=your-llm-model

# ── Embedding Model ───────────────────────────────────────────────────────────
# Runs locally via sentence-transformers — no API key needed.
# Note: Hardware device (cuda vs cpu) is now automatically detected in realtime.
EMBEDDING_MODEL=BAAI/bge-m3         # Multilingual/Vietnamese optimized model

# ── RAG settings ──────────────────────────────────────────────────────────────
CHUNK_MIN_TOKENS=30     # drop chunks shorter than this many tokens
NUM_RESULTS=5           # top-k articles retrieved per query

# ── ALQAC competition token ──────────────────────────────────────────────────────────────
ALQAC_TOKEN=alquac_token_here